PROJECT_NAME=Traffic AI Engine
VERSION=1.0.0
DESCRIPTION=Traffic event detection and tracking AI engine

HOST=0.0.0.0
PORT=8000
DEBUG=false

API_V1_PREFIX=/api/v1

ALLOWED_ORIGINS=*

MODEL_PATH=./weights/yolov8n.pt
MODEL_CONFIDENCE=0.25
MODEL_IOU=0.45
MODEL_DEVICE=cpu

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

TRACKER_MAX_AGE=30
TRACKER_MIN_HITS=3
TRACKER_IOU_THRESHOLD=0.3
